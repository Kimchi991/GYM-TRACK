<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTrackPro.Mobile.Views.ResetPasswordPage"
             Title="Reset Password"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="*" Padding="20">
            <Border StrokeShape="RoundRectangle 18" 
                    Stroke="{StaticResource BorderBrush}"
                    BackgroundColor="{StaticResource CardBackground}"
                    VerticalOptions="Center" 
                    MaximumWidthRequest="450" 
                    Padding="30"
                    Margin="0,40">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- Header -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Reset Password"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Enter token and new password."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Input Email -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Email Address *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding Email}" Keyboard="Email" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter registered email" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Input Token -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Reset Token *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding Token}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter reset token" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Input New Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="New Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding NewPassword}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter new password" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error Alert -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Success Alert -->
                    <Label Text="{Binding SuccessMessage}"
                           TextColor="{StaticResource Success}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Submit Button -->
                    <Button Text="Reset Password"
                            TextColor="White"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="8"
                            HeightRequest="48"
                            FontAttributes="Bold"
                            Command="{Binding ResetPasswordCommand}" />

                    <!-- Navigation Link -->
                    <Label Text="Back to Sign In" 
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"
                           FontSize="13"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
