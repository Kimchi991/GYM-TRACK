<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GymTrackPro.Mobile.ViewModels"
             x:Class="GymTrackPro.Mobile.Views.ReportsPage"
             Title="GymTrackPro Reports"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">
            
            <!-- Filters Card -->
            <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Report Filter Criteria" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />

                    <!-- Report Type -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Select Report Type *" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                        <Border StrokeShape="RoundRectangle 6" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Picker SelectedItem="{Binding ReportType}" TextColor="{StaticResource TextPrimary}" TitleColor="{StaticResource TextMuted}" HeightRequest="40">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Daily Revenue</x:String>
                                        <x:String>Attendance</x:String>
                                        <x:String>Membership Sales</x:String>
                                        <x:String>Refunds</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Date Range -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Start Date *" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            <Border StrokeShape="RoundRectangle 6" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <DatePicker Date="{Binding StartDate}" TextColor="{StaticResource TextPrimary}" HeightRequest="40" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="End Date *" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                            <Border StrokeShape="RoundRectangle 6" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <DatePicker Date="{Binding EndDate}" TextColor="{StaticResource TextPrimary}" HeightRequest="40" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Action buttons -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,5,0,0">
                        <Button Text="📊 Run Report"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                Command="{Binding GenerateReportCommand}" />

                        <Button Grid.Column="1"
                                Text="📥 Export CSV"
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                Command="{Binding ExportCsvCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Alerts / Output Messages -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

            <!-- Report Results Table Preview -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Report Preview (First 50 Rows)" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />

                <!-- Table Header -->
                <Border StrokeShape="RoundRectangle 8" BackgroundColor="{StaticResource CardBackground}" Padding="15,10" StrokeThickness="0">
                    <Grid ColumnDefinitions="2*, 2*, 2*, 2*">
                        <Label Text="Field 1" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" FontSize="12" />
                        <Label Grid.Column="1" Text="Field 2" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" FontSize="12" />
                        <Label Grid.Column="2" Text="Field 3" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" FontSize="12" />
                        <Label Grid.Column="3" Text="Field 4" TextColor="{StaticResource TextSecondary}" FontAttributes="Bold" FontSize="12" HorizontalOptions="End" />
                    </Grid>
                </Border>

                <!-- Table Rows -->
                <CollectionView ItemsSource="{Binding ReportRows}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No preview data. Run a report to see results." TextColor="{StaticResource TextMuted}" FontSize="13" HorizontalOptions="Center" Margin="0,20" />
                    </CollectionView.EmptyView>
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ReportItemDto">
                            <Border StrokeShape="RoundRectangle 0" StrokeThickness="0" BackgroundColor="Transparent" Padding="15,12">
                                <Grid ColumnDefinitions="2*, 2*, 2*, 2*">
                                    <Label Text="{Binding Col1}" TextColor="{StaticResource TextPrimary}" FontSize="13" />
                                    <Label Grid.Column="1" Text="{Binding Col2}" TextColor="{StaticResource TextPrimary}" FontSize="13" />
                                    <Label Grid.Column="2" Text="{Binding Col3}" TextColor="{StaticResource TextPrimary}" FontSize="13" />
                                    <Label Grid.Column="3" Text="{Binding Col4}" TextColor="{StaticResource TextPrimary}" FontSize="13" HorizontalOptions="End" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
