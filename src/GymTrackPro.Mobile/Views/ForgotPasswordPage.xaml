<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTrackPro.Mobile.Views.ForgotPasswordPage"
             Title="Reset Password Request"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="*" Padding="20">
            <Border StrokeShape="RoundRectangle 18" 
                    Stroke="{StaticResource BorderBrush}"
                    BackgroundColor="{StaticResource CardBackground}"
                    VerticalOptions="Center" 
                    MaximumWidthRequest="450" 
                    Padding="30"
                    Margin="0,40">
                <VerticalStackLayout Spacing="25">
                    
                    <!-- Header -->
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Forgot Password"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Enter email to request a reset token."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Input Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email Address" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding Email}" 
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   HeightRequest="45"
                                   Keyboard="Email"
                                   Placeholder="Enter registered email" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error Alert -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Success Alert -->
                    <Label Text="{Binding SuccessMessage}"
                           TextColor="{StaticResource Success}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Submit Button -->
                    <Button Text="Request Reset Link"
                            TextColor="White"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="8"
                            HeightRequest="48"
                            FontAttributes="Bold"
                            Command="{Binding ForgotPasswordCommand}" />

                    <!-- Links -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                        <Label Text="Back to Sign In" 
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
