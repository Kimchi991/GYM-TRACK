<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GymTrackPro.Mobile.ViewModels"
             x:Class="GymTrackPro.Mobile.Views.DashboardPage"
             Title="GymTrackPro Dashboard"
             BackgroundColor="{StaticResource Background}">



    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25" BackgroundColor="{StaticResource Background}">

            <!-- Welcome Header -->
            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Good Morning, Admin 👋"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="24"
                           FontAttributes="Bold" />
                    <Label Text="GymTrackPro Control Panel"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" />
                </VerticalStackLayout>
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <!-- Refresh Button -->
                    <Border StrokeShape="RoundRectangle 20" 
                            Stroke="{StaticResource BorderBrush}" 
                            BackgroundColor="{StaticResource CardBackground}" 
                            WidthRequest="40" 
                            HeightRequest="40"
                            Padding="10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDashboardDataCommand}" />
                        </Border.GestureRecognizers>
                        <Path Data="{StaticResource IconRefresh}" Fill="{StaticResource TextPrimary}" Aspect="Uniform" />
                    </Border>

                    <!-- Avatar Initials -->
                    <Border StrokeShape="RoundRectangle 20" 
                            Stroke="{StaticResource Primary}" 
                            StrokeThickness="2"
                            BackgroundColor="{StaticResource PrimaryDark}" 
                            WidthRequest="40" 
                            HeightRequest="40">
                        <Label Text="AD" 
                               TextColor="White" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- Metrics Grid -->
            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" ColumnSpacing="15" RowSpacing="15">
                <!-- Today's Revenue -->
                <Border StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0" HeightRequest="120">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Secondary}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconCard}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Today's Revenue" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding RevenueToday, StringFormat='₱{0:N2}'}" TextColor="{StaticResource Secondary}" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Cash/Digital payments" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Monthly Revenue -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0" HeightRequest="120">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Primary}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconChart}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Month's Revenue" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding RevenueThisMonth, StringFormat='₱{0:N2}'}" TextColor="{StaticResource Primary}" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Current billing period" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Members Checked In -->
                <Border Grid.Row="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0" HeightRequest="120">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Success}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconUser}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Checked In Today" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding CheckedInCount}" TextColor="{StaticResource Success}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Active check-in sessions" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Active Memberships -->
                <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0" HeightRequest="120">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Tertiary}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconCalendar}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Active Members" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding ActiveMembersCount}" TextColor="{StaticResource Tertiary}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Valid billing subscriptions" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Alerts Banner -->
            <Border StrokeShape="RoundRectangle 12" 
                    Stroke="{StaticResource Warning}" 
                    StrokeThickness="1"
                    BackgroundColor="#221C10" 
                    Padding="15"
                    IsVisible="{Binding ExpiringSoonCount, Converter={StaticResource NullableToBoolConverter}}">
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                    <Path Grid.Column="0" Data="{StaticResource IconWarning}" Fill="{StaticResource Warning}" Aspect="Uniform" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                    
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Action Required" TextColor="{StaticResource Warning}" FontSize="14" FontAttributes="Bold" />
                        <Label Text="{Binding ExpiringSoonCount, StringFormat='{0} memberships expiring within 3 days.'}" TextColor="{StaticResource TextPrimary}" FontSize="12" />
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="2" 
                            Text="View" 
                            BackgroundColor="{StaticResource Warning}" 
                            TextColor="Black" 
                            CornerRadius="6" 
                            HeightRequest="32" 
                            Padding="12,0" 
                            Command="{Binding NavigateToCommand}" 
                            CommandParameter="reports" />
                </Grid>
            </Border>

            <!-- Quick Actions -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Quick Actions" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="12">
                    
                    <!-- Check-In Action -->
                    <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="85">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="attendance" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconScan}" Fill="{StaticResource Primary}" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" />
                            <Label Text="Check-In" TextColor="{StaticResource TextPrimary}" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Add Member Action -->
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="85">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="members" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconPlus}" Fill="{StaticResource Secondary}" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" />
                            <Label Text="Add Member" TextColor="{StaticResource TextPrimary}" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Billing Action -->
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="85">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="payments" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconCard}" Fill="{StaticResource Tertiary}" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" />
                            <Label Text="Billing" TextColor="{StaticResource TextPrimary}" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Reports Action -->
                    <Border Grid.Column="3" StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="85">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="reports" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconChart}" Fill="{StaticResource Info}" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" />
                            <Label Text="Reports" TextColor="{StaticResource TextPrimary}" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
