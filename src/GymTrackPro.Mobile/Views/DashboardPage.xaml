<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GymTrackPro.Mobile.ViewModels"
             x:Class="GymTrackPro.Mobile.Views.DashboardPage"
             Title="GymTrackPro Dashboard"
             BackgroundColor="{StaticResource Background}">



    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,85" Spacing="25" BackgroundColor="{StaticResource Background}">

            <!-- Welcome Header -->
            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Good Morning, Admin"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="24"
                           FontAttributes="Bold" />
                    <Label Text="GymTrackPro Control Panel"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" />
                </VerticalStackLayout>
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <!-- Refresh Button -->
                    <Border StrokeShape="RoundRectangle 20" 
                            Stroke="{StaticResource BorderBrush}" 
                            BackgroundColor="{StaticResource CardBackground}" 
                            WidthRequest="40" 
                            HeightRequest="40"
                            Padding="10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadDashboardDataCommand}" />
                        </Border.GestureRecognizers>
                        <Path Data="{StaticResource IconRefresh}" Fill="{StaticResource TextPrimary}" Aspect="Uniform" />
                    </Border>

                    <!-- Logout Button -->
                    <Border StrokeShape="RoundRectangle 20"
                            Stroke="#EF4444"
                            StrokeThickness="1.5"
                            BackgroundColor="#1F0A0A"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="10"
                            x:Name="LogoutButton">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <!-- Sign-out icon path matching Lucide/Feather logout style -->
                        <Path Data="M 9 21 H 5 a 2 2 0 0 1 -2 -2 V 5 a 2 2 0 0 1 2 -2 H 9 M 16 17 L 21 12 L 16 7 M 21 12 H 9"
                              Stroke="#EF4444"
                              StrokeThickness="2.5"
                              StrokeLineCap="Round"
                              StrokeLineJoin="Round"
                              Aspect="Uniform" />
                    </Border>

                    <!-- Avatar Initials -->
                    <Border StrokeShape="RoundRectangle 20" 
                            Stroke="{StaticResource Primary}" 
                            StrokeThickness="2"
                            BackgroundColor="{StaticResource PrimaryDark}" 
                            WidthRequest="40" 
                            HeightRequest="40">
                        <Label Text="AD" 
                               TextColor="White" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- Metrics Grid -->
            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" ColumnSpacing="15" RowSpacing="15">
                <!-- Today's Revenue -->
                <Border StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Secondary}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconCard}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Today's Revenue" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding RevenueToday, StringFormat='₱{0:N2}'}" TextColor="{StaticResource Secondary}" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Cash/Digital payments" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Monthly Revenue -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Primary}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconChart}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Month's Revenue" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding RevenueThisMonth, StringFormat='₱{0:N2}'}" TextColor="{StaticResource Primary}" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Current billing period" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Members Checked In -->
                <Border Grid.Row="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Success}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconUser}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Checked In Today" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding CheckedInCount}" TextColor="{StaticResource Success}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Active check-in sessions" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Active Memberships -->
                <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E293B" Offset="0.0" />
                            <GradientStop Color="#0F172A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="5, *">
                        <BoxView Color="{StaticResource Tertiary}" WidthRequest="5" CornerRadius="4,0,4,0" VerticalOptions="Fill" />
                        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Padding="15" RowSpacing="4">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Path Data="{StaticResource IconCalendar}" Fill="{StaticResource TextSecondary}" Aspect="Uniform" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                                <Label Text="Active Members" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Row="1" Text="{Binding ActiveMembersCount}" TextColor="{StaticResource Tertiary}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Row="2" Text="Valid billing subscriptions" TextColor="{StaticResource TextMuted}" FontSize="10" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Alert Banners Stack -->
            <VerticalStackLayout Spacing="10">
                <!-- Expiring Members Alert -->
                <Border StrokeShape="RoundRectangle 12" 
                        Stroke="{StaticResource Warning}" 
                        StrokeThickness="1"
                        BackgroundColor="#221C10" 
                        Padding="15"
                        IsVisible="{Binding ExpiringSoonCount, Converter={StaticResource NullableToBoolConverter}}">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Path Grid.Column="0" Data="{StaticResource IconWarning}" Fill="{StaticResource Warning}" Aspect="Uniform" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Action Required" TextColor="{StaticResource Warning}" FontSize="14" FontAttributes="Bold" />
                            <Label Text="{Binding ExpiringSoonCount, StringFormat='{0} memberships expiring within 3 days.'}" TextColor="{StaticResource TextPrimary}" FontSize="12" />
                        </VerticalStackLayout>
                        
                        <Button Grid.Column="2" 
                                Text="View" 
                                BackgroundColor="{StaticResource Warning}" 
                                TextColor="Black" 
                                CornerRadius="6" 
                                HeightRequest="32" 
                                Padding="12,0" 
                                Command="{Binding NavigateToCommand}" 
                                CommandParameter="reports" />
                    </Grid>
                </Border>

                <!-- Pending Applications Alert -->
                <Border StrokeShape="RoundRectangle 12" 
                        Stroke="{StaticResource Info}" 
                        StrokeThickness="1"
                        BackgroundColor="#0B202F" 
                        Padding="15"
                        IsVisible="{Binding PendingApplicationsCount, Converter={StaticResource NullableToBoolConverter}}">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                        <Path Grid.Column="0" Data="{StaticResource IconCheckCircle}" Fill="{StaticResource Info}" Aspect="Uniform" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Verification Required" TextColor="{StaticResource Info}" FontSize="14" FontAttributes="Bold" />
                            <Label Text="{Binding PendingApplicationsCount, StringFormat='{0} registration applications pending verification.'}" TextColor="{StaticResource TextPrimary}" FontSize="12" />
                        </VerticalStackLayout>
                        
                        <Button Grid.Column="2" 
                                Text="Review" 
                                BackgroundColor="{StaticResource Info}" 
                                TextColor="White" 
                                CornerRadius="6" 
                                HeightRequest="32" 
                                Padding="12,0" 
                                Command="{Binding NavigateToCommand}" 
                                CommandParameter="applications" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Quick Actions -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Quick Actions" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="12" RowSpacing="12">
                    
                    <!-- Check-In Action (Row 0, Col 0) -->
                    <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="100">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="attendance" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconScan}" Fill="{StaticResource Primary}" Aspect="Uniform" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" />
                            <Label Text="Check-In" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Add Member Action (Row 0, Col 1) -->
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="100">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="members" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconPlus}" Fill="{StaticResource Secondary}" Aspect="Uniform" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" />
                            <Label Text="Add Member" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Billing Action (Row 1, Col 0) -->
                    <Border Grid.Row="1" StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="100">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="payments" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconCard}" Fill="{StaticResource Tertiary}" Aspect="Uniform" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" />
                            <Label Text="Billing" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Reports Action (Row 1, Col 1) -->
                    <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="10" HeightRequest="100">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="reports" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                            <Path Data="{StaticResource IconChart}" Fill="{StaticResource Info}" Aspect="Uniform" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" />
                            <Label Text="Reports" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Owner-only Staff Provisioning (API enforces authorization) -->
                    <Button Grid.Row="2"
                            Grid.ColumnSpan="2"
                            IsVisible="{Binding CanManageStaff}"
                            Text="Add Receptionist&#10;Create a staff profile and one-time invite"
                            Command="{Binding NavigateToStaffProvisioningCommand}"
                            BackgroundColor="{StaticResource CardBackground}"
                            BorderColor="{StaticResource BorderBrush}"
                            BorderWidth="1"
                            TextColor="{StaticResource TextPrimary}"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Padding="14"
                            MinimumHeightRequest="86"
                            SemanticProperties.Description="Add Receptionist"
                            SemanticProperties.Hint="Owner action. Opens the form for creating a Receptionist profile and one-time activation invite." />
                </Grid>
            </VerticalStackLayout>

            <!-- Live Gym Occupancy List -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Live Gym Occupancy" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="No members currently checked in." TextColor="{StaticResource TextMuted}" FontSize="13" HorizontalOptions="Center" Margin="0,10" IsVisible="{Binding HasCheckedInMembers, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}" />
                        
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding CurrentlyCheckedIn}" IsVisible="{Binding HasCheckedInMembers}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout>
                                        <Grid ColumnDefinitions="*, Auto" Padding="0,8">
                                            <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding MemberName}" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" />
                                                <Label Text="{Binding PlanName}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding CheckInTime, StringFormat='{0:hh:mm tt}'}" TextColor="{StaticResource Success}" FontSize="13" FontAttributes="Bold" HorizontalOptions="End" />
                                                <Label Text="Checked In" TextColor="{StaticResource TextMuted}" FontSize="10" HorizontalOptions="End" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <!-- Separator Line -->
                                        <BoxView HeightRequest="1" Color="#334155" HorizontalOptions="Fill" Margin="0,2" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Membership Plan Distribution Analytics -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Active Plan Analytics" TextColor="{StaticResource TextPrimary}" FontSize="16" FontAttributes="Bold" />
                <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="No active plan analytics available." TextColor="{StaticResource TextMuted}" FontSize="13" HorizontalOptions="Center" Margin="0,10" IsVisible="{Binding HasPlanDistribution, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}" />
                        
                        <FlexLayout BindableLayout.ItemsSource="{Binding MembershipPlanDistribution}" Wrap="Wrap" JustifyContent="SpaceBetween" AlignItems="Center" AlignContent="Center" IsVisible="{Binding HasPlanDistribution}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="15" Margin="0,5" WidthRequest="150" HeightRequest="90">
                                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding ActiveMembersCount}" TextColor="{StaticResource Primary}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
                                            <Label Text="{Binding PlanName}" TextColor="{StaticResource TextPrimary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
