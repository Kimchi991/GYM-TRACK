<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTrackPro.Mobile.Views.RegisterPage"
             Title="Create Account &amp; Apply"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="*" Padding="20">
            <Border StrokeShape="RoundRectangle 18" 
                    Stroke="{StaticResource BorderBrush}"
                    BackgroundColor="{StaticResource CardBackground}"
                    VerticalOptions="Center" 
                    MaximumWidthRequest="450" 
                    Padding="30"
                    Margin="0,40">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- Header -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="{Binding Title}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Fill out your application below."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="20" IsVisible="{Binding ShowRegistration}">
                        
                        <Label Text="Account Details" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" Margin="0,10,0,0"/>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Email Address *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding Email}" Keyboard="Email" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter your email" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding Password}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Create password" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Repeat Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding RepeatPassword}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Repeat password" />
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource BorderBrush}" Margin="0,10" />
                        
                        <Label Text="Application Details" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Full Name *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding FullName}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="John Doe" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Contact Number *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding ContactNumber}" Keyboard="Telephone" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="+1 234 567 890" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Emergency Contact" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding EmergencyContact}" Keyboard="Telephone" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Optional" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <!-- Membership Type Toggle -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Membership Type *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <HorizontalStackLayout Spacing="15" Margin="0,5">
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <RadioButton Content="One-Day Pass (Walk-in)" IsChecked="{Binding IsOneDayPass}" GroupName="MemType" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <RadioButton Content="Membership Plan" IsChecked="{Binding IsMembershipSelected}" GroupName="MemType" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Plan Picker (Visible if Membership Selected) -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding IsMembershipSelected}">
                            <Label Text="Select Membership Plan *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Picker Title="Choose a Plan" 
                                        ItemsSource="{Binding MembershipPlans}" 
                                        ItemDisplayBinding="{Binding PlanName}"
                                        SelectedItem="{Binding SelectedPlan}" 
                                        TextColor="{StaticResource TextPrimary}" 
                                        HeightRequest="42" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Payment Method *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Picker Title="Choose a Method" 
                                        ItemsSource="{Binding PaymentMethods}" 
                                        SelectedItem="{Binding SelectedPaymentMethod}" 
                                        TextColor="{StaticResource TextPrimary}" 
                                        HeightRequest="42" />
                            </Border>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Payment Reference Number" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding PaymentReferenceNumber}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="For Bank Transfers/E-wallets" />
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Create FitHub Account &amp; Apply"
                                TextColor="White"
                                BackgroundColor="{StaticResource Primary}"
                                CornerRadius="8"
                                HeightRequest="48"
                                FontAttributes="Bold"
                                Command="{Binding RegisterCommand}" 
                                Margin="0,15,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12" IsVisible="{Binding ShowActivation}">
                        <Label Text="After opening the verification email, enter the invite again and confirm activation. The invite is never stored on this device."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               HorizontalTextAlignment="Center" />
                        <Button Text="Resend Verification Email"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource Primary}"
                                BorderWidth="1"
                                CornerRadius="8"
                                HeightRequest="44"
                                IsEnabled="{Binding IsResendingVerification, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}"
                                Command="{Binding ResendVerificationCommand}" />
                        <ActivityIndicator IsRunning="{Binding IsResendingVerification}"
                                           IsVisible="{Binding IsResendingVerification}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />
                        <Label Text="Invite Code *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding InviteCode}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter your gym invite code" />
                        </Border>
                        <Button Text="I've Verified - Activate"
                                TextColor="White"
                                BackgroundColor="{StaticResource Secondary}"
                                CornerRadius="8"
                                HeightRequest="48"
                                FontAttributes="Bold"
                                Command="{Binding VerifyAndActivateCommand}" />
                    </VerticalStackLayout>

                    <!-- Error Alert -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Success Alert -->
                    <Label Text="{Binding SuccessMessage}"
                           TextColor="{StaticResource Success}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Navigation link -->
                    <Label Text="Already have an account? Sign In" 
                           TextColor="{StaticResource Secondary}"
                           HorizontalOptions="Center"
                           FontSize="13"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
