<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTrackPro.Mobile.Views.RegisterPage"
             Title="Create Account"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="*" Padding="20">
            <Border StrokeShape="RoundRectangle 18" 
                    Stroke="{StaticResource BorderBrush}"
                    BackgroundColor="{StaticResource CardBackground}"
                    VerticalOptions="Center" 
                    MaximumWidthRequest="450" 
                    Padding="30"
                    Margin="0,40">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- Header -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Create Account"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Sign up to manage your facility"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Input Username -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Username *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding Username}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Choose a username" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Input Email -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Email Address *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding Email}" Keyboard="Email" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter email address" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Name Grid -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="First Name *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding FirstName}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="First Name" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Last Name *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding LastName}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Last Name" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Invite Code (Optional) -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Invite Code (Optional)" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding InviteCode}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter invite code if you have one" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Input Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding Password}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Create password" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Repeat Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Repeat Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding RepeatPassword}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Repeat password" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error Alert -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Success Alert -->
                    <Label Text="{Binding SuccessMessage}"
                           TextColor="{StaticResource Success}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Submit Button -->
                    <Button Text="Register Account"
                            TextColor="White"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="8"
                            HeightRequest="48"
                            FontAttributes="Bold"
                            Command="{Binding RegisterCommand}" />


                    <!-- Navigation link -->
                    <Label Text="Already have an account? Sign In" 
                           TextColor="{StaticResource Secondary}"
                           HorizontalOptions="Center"
                           FontSize="13"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
