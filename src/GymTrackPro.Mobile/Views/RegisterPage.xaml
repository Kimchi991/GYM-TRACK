<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GymTrackPro.Mobile.Views.RegisterPage"
             Title="Create Account"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="*" Padding="20">
            <Border StrokeShape="RoundRectangle 18" 
                    Stroke="{StaticResource BorderBrush}"
                    BackgroundColor="{StaticResource CardBackground}"
                    VerticalOptions="Center" 
                    MaximumWidthRequest="450" 
                    Padding="30"
                    Margin="0,40">
                <VerticalStackLayout Spacing="20">
                    
                    <!-- Header -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="{Binding Title}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Firebase verifies your email; your gym invite grants app access."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="20" IsVisible="{Binding ShowRegistration}">
                        <!-- Member/staff names come from the gym invite target in SQL. -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Email Address *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding Email}" Keyboard="Email" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Use the email on your gym invite" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding Password}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Create password" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Repeat Password *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding RepeatPassword}" IsPassword="True" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Repeat password" />
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Create Firebase Account"
                                TextColor="White"
                                BackgroundColor="{StaticResource Primary}"
                                CornerRadius="8"
                                HeightRequest="48"
                                FontAttributes="Bold"
                                Command="{Binding RegisterCommand}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12" IsVisible="{Binding ShowActivation}">
                        <Label Text="After opening the Firebase verification email, enter the invite again and confirm activation. The invite is never stored on this device."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               HorizontalTextAlignment="Center" />
                        <Button Text="Resend Verification Email"
                                TextColor="{StaticResource Primary}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource Primary}"
                                BorderWidth="1"
                                CornerRadius="8"
                                HeightRequest="44"
                                IsEnabled="{Binding IsResendingVerification, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}"
                                Command="{Binding ResendVerificationCommand}" />
                        <ActivityIndicator IsRunning="{Binding IsResendingVerification}"
                                           IsVisible="{Binding IsResendingVerification}"
                                           Color="{StaticResource Primary}"
                                           HorizontalOptions="Center" />
                        <Label Text="Invite Code *" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                            <Entry Text="{Binding InviteCode}" TextColor="{StaticResource TextPrimary}" PlaceholderColor="{StaticResource TextMuted}" HeightRequest="42" Placeholder="Enter your gym invite code" />
                        </Border>
                        <Button Text="I've Verified - Activate"
                                TextColor="White"
                                BackgroundColor="{StaticResource Secondary}"
                                CornerRadius="8"
                                HeightRequest="48"
                                FontAttributes="Bold"
                                Command="{Binding VerifyAndActivateCommand}" />
                    </VerticalStackLayout>

                    <!-- Error Alert -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Success Alert -->
                    <Label Text="{Binding SuccessMessage}"
                           TextColor="{StaticResource Success}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           IsVisible="{Binding SuccessMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Navigation link -->
                    <Label Text="Already have an account? Sign In" 
                           TextColor="{StaticResource Secondary}"
                           HorizontalOptions="Center"
                           FontSize="13"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
