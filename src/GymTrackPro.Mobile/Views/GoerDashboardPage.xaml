<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GymTrackPro.Mobile.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="GymTrackPro.Mobile.Views.GoerDashboardPage"
             Title="{Binding Title}"
             BackgroundColor="#0F172A">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <!-- Header. The image bytes are fetched through the authenticated API;
                 the UI never binds to the protected endpoint as a public URI. -->
            <Grid ColumnDefinitions="72,*" ColumnSpacing="14">
                <Border WidthRequest="64"
                        HeightRequest="64"
                        Padding="0"
                        BackgroundColor="#334155"
                        Stroke="#475569"
                        StrokeShape="RoundRectangle 32">
                    <Grid>
                        <Label Text="GP"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#CBD5E1"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="{Binding ShowDefaultProfilePicture}" />
                        <Image Source="{Binding ProfilePictureSource}"
                               Aspect="AspectFill"
                               IsVisible="{Binding HasProfilePicture}" />
                    </Grid>
                </Border>
                <Label Grid.Column="1"
                       Text="Welcome back!"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#F8FAFC"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Digital Gate Pass / QR Code -->
            <Border StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderBrush}" Padding="20" BackgroundColor="{StaticResource CardBackground}" HorizontalOptions="Fill">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="Scan Gate Pass" TextColor="{StaticResource TextSecondary}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                    
                    <Border StrokeShape="RoundRectangle 8" Padding="10" BackgroundColor="White" WidthRequest="160" HeightRequest="160" HorizontalOptions="Center">
                        <zxing:BarcodeGeneratorView 
                            Value="{Binding QrCodeValue}"
                            Format="QrCode"
                            HeightRequest="140"
                            WidthRequest="140"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            BackgroundColor="White" />
                    </Border>
                    
                    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Plan Expiry:" TextColor="{StaticResource TextMuted}" FontSize="12" />
                        <Label Text="{Binding CountdownMessage}" TextColor="{StaticResource Success}" FontSize="12" FontAttributes="Bold" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Subscription Status -->
            <Border BackgroundColor="#1E293B" Padding="20" Stroke="Transparent" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Membership Status" FontSize="16" TextColor="#94A3B8" />
                    <Label Text="{Binding DashboardData.MembershipStatus, TargetNullValue='No Active Plan'}" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#F8FAFC" />
                </VerticalStackLayout>
            <!-- Live Gym Occupancy Widget -->
            <Border BackgroundColor="#1E293B" Padding="20" Stroke="Transparent" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="👥 Live Gym Capacity" FontSize="15" TextColor="#94A3B8" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding OccupancyStatus}" FontSize="13" TextColor="#10B981" FontAttributes="Bold" />
                    </Grid>
                    <Label Text="{Binding OccupancyText}" FontSize="18" FontAttributes="Bold" TextColor="#F8FAFC" />
                    <ProgressBar Progress="{Binding OccupancyRatio}" ProgressColor="#3B82F6" HeightRequest="8" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#1E293B" Padding="20" Stroke="Transparent" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Current Streak" FontSize="16" TextColor="#94A3B8" />
                    <Label Text="{Binding DashboardData.CurrentStreak}" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#10B981" />
                </VerticalStackLayout>
            </Border>
            
            <Border BackgroundColor="#1E293B" Padding="20" Stroke="Transparent" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Total Visits" FontSize="16" TextColor="#94A3B8" />
                    <Label Text="{Binding DashboardData.VisitCount}" 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="#3B82F6" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#1E293B" Padding="20" Stroke="Transparent" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Time Spent in Gym (Minutes)" FontSize="16" TextColor="#94A3B8" />
                    <Label Text="{Binding DashboardData.CurrentMonthMinutes}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#F59E0B" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#1E293B" Padding="20" Stroke="Transparent" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Milestone Badges" FontSize="16" TextColor="#94A3B8" />
                    <CollectionView ItemsSource="{Binding DashboardData.UnlockedBadges}" HeightRequest="50">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#3B82F6" Padding="10" Margin="0,0,10,0" Stroke="Transparent" StrokeShape="RoundRectangle 8">
                                    <Label Text="{Binding .}" TextColor="White" FontAttributes="Bold" VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Option 2: My Workout Routine (Assigned by Trainer) -->
            <VerticalStackLayout Spacing="12">
                <Label Text="My Workout Routine" TextColor="#F8FAFC" FontSize="18" FontAttributes="Bold" />
                <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource CardBackground}" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding RoutineName}" TextColor="{StaticResource Primary}" FontSize="15" FontAttributes="Bold" />
                        
                        <Label Text="No exercises assigned yet." TextColor="{StaticResource TextMuted}" FontSize="13" IsVisible="{Binding HasAssignedRoutine, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}" />
                        
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding WorkoutExercises}" IsVisible="{Binding HasAssignedRoutine}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout>
                                        <Grid ColumnDefinitions="*, Auto" Padding="0,10">
                                            <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" />
                                                <Label Text="{Binding Weight, StringFormat='Weight: {0} kg'}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding Sets, StringFormat='{0} Sets'}" TextColor="{StaticResource Info}" FontSize="13" FontAttributes="Bold" HorizontalOptions="End" />
                                                <Label Text="{Binding Reps, StringFormat='{0} Reps'}" TextColor="{StaticResource TextMuted}" FontSize="11" HorizontalOptions="End" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <!-- Separator -->
                                        <BoxView HeightRequest="1" Color="#334155" HorizontalOptions="Fill" Margin="0,2" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        
                        <Button Text="✓ Complete Workout Session"
                                Command="{Binding CompleteWorkoutCommand}"
                                IsVisible="{Binding HasAssignedRoutine}"
                                IsEnabled="{Binding IsWorkoutLogging, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}"
                                BackgroundColor="{StaticResource Success}"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="8"
                                Margin="0,10,0,0" />

                        <Label Text="{Binding WorkoutLogStatusMessage}"
                               TextColor="{StaticResource Success}"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               IsVisible="{Binding WorkoutLogStatusMessage, Converter={StaticResource NullableToBoolConverter}}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Label Text="{Binding AttendanceStatusMessage}"
                   TextColor="#93C5FD"
                   IsVisible="{Binding AttendanceStatusMessage, Converter={StaticResource NullableToBoolConverter}}" />
            <Label Text="{Binding AttendanceErrorMessage}"
                   TextColor="#FCA5A5"
                   IsVisible="{Binding AttendanceErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsAttendanceLoading}"
                               IsVisible="{Binding IsAttendanceLoading}"
                               Color="#3B82F6" />

            <Border BackgroundColor="#1E293B"
                   Padding="20"
                   Stroke="Transparent"
                   StrokeShape="RoundRectangle 12"
                   IsVisible="{Binding DashboardData.CurrentSession, Converter={StaticResource NullableToBoolConverter}}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Current Session" FontSize="16" TextColor="#94A3B8" />
                    <Label Text="Checked in"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#10B981" />
                    <Label Text="{Binding DashboardData.CurrentSession.CheckInTime, StringFormat='Since {0:g}'}"
                           TextColor="#CBD5E1" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label Text="Recent Attendance"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#F8FAFC" />
                <Label Text="No attendance history yet."
                       TextColor="#94A3B8"
                       IsVisible="{Binding IsAttendanceEmpty}" />
                <CollectionView ItemsSource="{Binding RecentAttendance}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1E293B"
                                   Padding="12"
                                   Margin="0,0,0,8"
                                   Stroke="Transparent"
                                   StrokeShape="RoundRectangle 8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Text="{Binding AttendanceDate, StringFormat='{0:MMM d, yyyy}'}"
                                           FontAttributes="Bold"
                                           TextColor="#F8FAFC" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Source}"
                                           TextColor="#94A3B8"
                                           FontSize="12" />
                                    <Label Grid.Row="1"
                                           Text="{Binding CheckInTime, StringFormat='In: {0:t}'}"
                                           TextColor="#CBD5E1" />
                                    <Label Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding CheckOutTime, StringFormat='Out: {0:t}', TargetNullValue='Open'}"
                                           TextColor="#CBD5E1" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Button Text="Refresh" Command="{Binding LoadDataCommand}" BackgroundColor="#3B82F6" TextColor="White" CornerRadius="8" />

            <!-- Self Check-in / out -->
            <Button Text="Check In"
                    Command="{Binding CheckInCommand}"
                    IsVisible="{Binding DashboardData.CurrentSession, Converter={StaticResource NullableToBoolConverter}, ConverterParameter=invert}"
                    BackgroundColor="#10B981"
                    TextColor="White"
                    CornerRadius="8" />

            <Button Text="Check Out"
                    Command="{Binding CheckOutCommand}"
                    IsVisible="{Binding DashboardData.CurrentSession, Converter={StaticResource NullableToBoolConverter}}"
                    BackgroundColor="#F59E0B"
                    TextColor="White"
                    CornerRadius="8" />
            
            <Button Text="Logout" Command="{Binding LogoutCommand}" BackgroundColor="Transparent" TextColor="#EF4444" Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
