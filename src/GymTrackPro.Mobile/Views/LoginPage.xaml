<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GymTrackPro.Mobile.ViewModels"
             x:Class="GymTrackPro.Mobile.Views.LoginPage"
             Title="GymTrackPro Login"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <Grid RowDefinitions="*" Padding="20">
            <Border StrokeShape="RoundRectangle 18" 
                    Stroke="{StaticResource BorderBrush}"
                    BackgroundColor="{StaticResource CardBackground}"
                    VerticalOptions="Center" 
                    MaximumWidthRequest="450" 
                    Padding="30"
                    Margin="0,50">
                <VerticalStackLayout Spacing="25">
                    
                    <!-- Branding Header -->
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Path Data="{StaticResource IconLock}" Fill="{StaticResource Primary}" Aspect="Uniform" WidthRequest="32" HeightRequest="32" VerticalOptions="Center" />
                            <Label Text="GymTrackPro"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Text="Welcome Back"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="Sign in to manage your facility"
                               TextColor="{StaticResource TextMuted}"
                               FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Input Fields -->
                    <VerticalStackLayout Spacing="15">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email Address" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Entry Text="{Binding Email}" 
                                       TextColor="{StaticResource TextPrimary}"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       HeightRequest="52"
                                       Keyboard="Email"
                                       Placeholder="Enter email address" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" TextColor="{StaticResource TextSecondary}" FontSize="13" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource BorderBrush}" BackgroundColor="{StaticResource Background}" Padding="10,0">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Entry Grid.Column="0"
                                           Text="{Binding Password}" 
                                           TextColor="{StaticResource TextPrimary}"
                                           PlaceholderColor="{StaticResource TextMuted}"
                                           HeightRequest="52"
                                           IsPassword="{Binding IsPasswordHidden}" 
                                           Placeholder="Enter password" />
                                    <Label Grid.Column="1"
                                           Text="Show"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           Margin="5,0"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                                        </Label.GestureRecognizers>
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPasswordHidden}" Value="False">
                                                <Setter Property="Text" Value="Hide" />
                                                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Error Alert -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullableToBoolConverter}}" />

                    <!-- Login Button -->
                    <Button Text="Login"
                            TextColor="White"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="8"
                            HeightRequest="54"
                            FontSize="16"
                            FontAttributes="Bold"
                            Command="{Binding LoginCommand}" />


                    <!-- Navigation Links -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                        <Label Text="Forgot Password?" 
                               TextColor="{StaticResource Primary}"
                               FontSize="13"
                               FontAttributes="Bold"
                               Padding="12,8">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text="|" TextColor="{StaticResource BorderColor}" />
                        <Label Text="Register Account" 
                               TextColor="{StaticResource Secondary}"
                               FontSize="13"
                               FontAttributes="Bold"
                               Padding="12,8">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Loading Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
