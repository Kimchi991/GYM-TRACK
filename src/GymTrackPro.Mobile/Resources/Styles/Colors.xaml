<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Premium GymTrackPro Slate Dark Theme -->
    <Color x:Key="Primary">#3B82F6</Color> <!-- Electric Blue -->
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryLight">#60A5FA</Color>
    <Color x:Key="Secondary">#10B981</Color> <!-- Emerald Green -->
    <Color x:Key="SecondaryDarkText">#059669</Color>
    <Color x:Key="Tertiary">#F59E0B</Color> <!-- Amber/Gold -->
    
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color> <!-- Red -->
    <Color x:Key="Info">#06B6D4</Color>

    <Color x:Key="White">#F8FAFC</Color> <!-- Slate 50 -->
    <Color x:Key="Black">#090D16</Color> <!-- Deep Dark -->
    <Color x:Key="Background">#0F172A</Color> <!-- Slate 900 -->
    <Color x:Key="CardBackground">#1E293B</Color> <!-- Slate 800 -->
    <Color x:Key="BorderColor">#334155</Color> <!-- Slate 700 -->
    
    <!-- Standard Gray Palette (mapped to Premium Slate shades) -->
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#0F172A</Color>
    <Color x:Key="Gray950">#020617</Color>

    <Color x:Key="TextPrimary">#F8FAFC</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color> <!-- Slate 400 -->
    <Color x:Key="TextMuted">#64748B</Color> <!-- Slate 500 -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
</ResourceDictionary>