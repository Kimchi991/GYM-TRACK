<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GymTrackPro.Mobile.GoerAppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="My GymTrack"
    Shell.NavBarHasShadow="False"
    Shell.BackgroundColor="#0F172A"
    Shell.TitleColor="#F8FAFC"
    Shell.ForegroundColor="#F8FAFC"
    Shell.TabBarBackgroundColor="#1E293B"
    Shell.TabBarForegroundColor="#94A3B8"
    Shell.TabBarTitleColor="#94A3B8"
    Shell.TabBarUnselectedColor="#475569">

    <!-- Main Navigation TabBar -->
    <TabBar>
        <Tab Title="Dashboard" Route="goerdashboard">
            <ShellContent x:Name="DashboardContent" />
        </Tab>

        <Tab Title="My Progress" Route="goerprogress">
            <ShellContent x:Name="ProgressContent" />
        </Tab>

        <Tab Title="Digital Card" Route="goerdigitalcard">
            <ShellContent x:Name="DigitalCardContent" />
        </Tab>
    </TabBar>

</Shell>
