<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GymTrackPro.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GymTrackPro.Mobile.Views"
    Title="GymTrackPro"
    Shell.NavBarHasShadow="False"
    Shell.BackgroundColor="#0F172A"
    Shell.TitleColor="#F8FAFC"
    Shell.ForegroundColor="#F8FAFC"
    Shell.TabBarBackgroundColor="#1E293B"
    Shell.TabBarForegroundColor="#94A3B8"
    Shell.TabBarTitleColor="#94A3B8"
    Shell.TabBarUnselectedColor="#475569">

    <!-- Login Route (Tabs hidden) -->
    <ShellItem Route="login" FlyoutItemIsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate views:LoginPage}" />
    </ShellItem>

    <!-- Main Navigation TabBar -->
    <TabBar>
        <Tab Title="Dashboard" Route="dashboard">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" />
        </Tab>

        <Tab Title="Members" Route="members">
            <ShellContent ContentTemplate="{DataTemplate views:MembersPage}" />
        </Tab>

        <Tab Title="Attendance" Route="attendance">
            <ShellContent ContentTemplate="{DataTemplate views:AttendancePage}" />
        </Tab>

        <Tab Title="Payments" Route="payments">
            <ShellContent ContentTemplate="{DataTemplate views:PaymentsPage}" />
        </Tab>

        <Tab Title="More" Route="more">
            <ShellContent Title="Settings" Route="settings" ContentTemplate="{DataTemplate views:SettingsPage}" />
            <ShellContent Title="Membership Plans" Route="plans" ContentTemplate="{DataTemplate views:PlansPage}" />
            <ShellContent Title="Reports" Route="reports" ContentTemplate="{DataTemplate views:ReportsPage}" />
            <ShellContent Title="Notifications" Route="notifications" ContentTemplate="{DataTemplate views:NotificationsPage}" />
        </Tab>
    </TabBar>

</Shell>
